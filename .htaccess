RewriteEngine On

# Allow only trusted hostnames to prevent host header injection.
RewriteCond %{HTTP_HOST} !^(tzmc\.co\.il|www\.tzmc\.co\.il)(:\d+)?$ [NC]
RewriteRule ^ - [R=400,L]

# Canonical redirect must use a fixed hostname (never user-supplied host header).
RewriteCond %{HTTP_HOST} ^tzmc\.co\.il(:\d+)?$ [NC]
RewriteRule ^ https://www.tzmc.co.il%{REQUEST_URI} [R=301,L]

# Deny direct client probes for classic script extensions.
RewriteCond %{THE_REQUEST} \s/+[^\s]*\.(?:cgi|asp|aspx|php)(?:[\s?]|$) [NC]
RewriteRule \.(?:cgi|asp|aspx|php)$ - [F,L,NC]
