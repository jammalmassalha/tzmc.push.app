{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "notify-api",
      "urls": [
        "https://www.tzmc.co.il/notify/version**",
        "https://www.tzmc.co.il/notify/groups**",
        "https://www.tzmc.co.il/notify/messages**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 80,
        "maxAge": "1h",
        "timeout": "5s"
      }
    },
    {
      "name": "contacts-api",
      "urls": [
        "https://script.google.com/macros/s/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 30,
        "maxAge": "6h"
      }
    }
  ]
}
