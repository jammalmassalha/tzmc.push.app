<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- APNs environment.  "development" is used for debug/simulator builds.
	     When exporting a distribution IPA the signing profile overwrites this
	     value with "production" automatically. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
